    "Native PDF Reader uses the system PDF engine and works best for text-heavy PDF books." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der native PDF-Reader verwendet die systemeigene PDF-Engine und eignet sich am besten für textlastige PDF-Bücher."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Native PDF Reader uses the system PDF engine and works best for text-heavy PDF books."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El lector PDF nativo usa el motor PDF del sistema y funciona mejor con libros PDF de mucho texto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le lecteur PDF natif utilise le moteur PDF du système et convient le mieux aux livres PDF principalement textuels."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il lettore PDF nativo usa il motore PDF di sistema e funziona al meglio con libri PDF ricchi di testo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ネイティブPDFリーダーはシステムのPDFエンジンを使用し、文字中心のPDF書籍に最適です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기본 PDF 리더는 시스템 PDF 엔진을 사용하며 텍스트 위주의 PDF 책에 가장 적합합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нативный PDF-ридер использует системный PDF-движок и лучше всего подходит для PDF-книг с большим количеством текста."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "原生 PDF 阅读器使用系统 PDF 引擎，更适合以文字为主的 PDF 书籍。"
