    "Render a subtle shadow around pages. Turn off for seamless dual-page spreads." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeigt einen dezenten Schatten um Seiten an. Deaktivieren Sie ihn für nahtlose Doppelseiten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Render a subtle shadow around pages. Turn off for seamless dual-page spreads."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muestra una sombra sutil alrededor de las páginas. Desactívala para dobles páginas continuas sin separación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoute une ombre légère autour des pages. Désactivez-la pour des doubles pages sans séparation visible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostra una leggera ombra intorno alle pagine. Disattivala per doppie pagine senza separazione visibile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ページの周囲に控えめな影を付けます。見開きを継ぎ目なく表示したい場合はオフにしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "페이지 둘레에 은은한 그림자를 표시합니다. 이음새 없는 양면 펼침을 원하면 끄세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавляет легкую тень вокруг страниц. Отключите для бесшовных двухстраничных разворотов."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在页面周围渲染柔和阴影。若想让双页跨页无缝拼接，请关闭此项。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在頁面周圍顯示柔和陰影。若想讓雙頁跨頁無縫拼接，請關閉此選項。"
          }
        }
      }
    },
