    "Largest offline files. Best for heavy zooming and large screens." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die größten Offline-Dateien. Am besten für starkes Zoomen und große Bildschirme."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Largest offline files. Best for heavy zooming and large screens."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archivos offline mas grandes. Ideal para mucho zoom y pantallas grandes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les fichiers hors ligne les plus volumineux. Idéal pour un zoom important et les grands écrans."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "File offline piu grandi. Ideale per zoom intenso e schermi grandi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "オフラインファイルは最大になります。大きく拡大する場合や大画面に最適です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오프라인 파일 크기가 가장 커집니다. 큰 화면이나 강한 확대에 가장 적합합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Самые большие офлайн-файлы. Лучше всего для сильного увеличения и больших экранов."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "离线文件最大，最适合大幅缩放和大屏设备。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "離線檔案最大，最適合大幅縮放和大螢幕裝置。"
          }
        }
      }
    },
