    "Adjust the maximum size of the cover cache. Cache will be cleaned automatically when exceeded." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passen Sie die maximale Größe des Cover-Caches an. Der Cache wird automatisch geleert, wenn er überschritten wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust the maximum size of the cover cache. Cache will be cleaned automatically when exceeded."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta el tamano maximo de la cache de portadas. Se limpiara automaticamente al superarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajustez la taille maximale du cache des couvertures. Le cache sera nettoyé automatiquement en cas de dépassement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regola la dimensione massima della cache delle copertine. La cache verra pulita automaticamente quando superata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カバーキャッシュの最大サイズを調整します。超過時は自動でクリーンされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "커버 캐시의 최대 크기를 조정합니다. 초과하면 자동으로 정리됩니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Настройте максимальный размер кэша обложек. При превышении кэш будет очищен автоматически."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调节封面缓存上限，超出将自动清理。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "調節封面快取上限，超出將自動清理。"
          }
        }
      }
    },
