    "dashboard.sections.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziehen Sie zum Neuordnen der Abschnitte. Schalten Sie ein/aus, um anzuzeigen oder zu verbergen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drag to reorder sections. Toggle to show or hide."
          }
        },
