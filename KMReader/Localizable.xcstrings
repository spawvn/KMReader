    "Pull to refresh to recalculate reading stats from local data." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zum Aktualisieren nach unten ziehen, um Lesestatistiken aus lokalen Daten neu zu berechnen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pull to refresh to recalculate reading stats from local data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desliza para actualizar y recalcular estadisticas de lectura desde datos locales."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tirez pour actualiser afin de recalculer les statistiques de lecture à partir des données locales."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascina per aggiornare e ricalcolare le statistiche di lettura dai dati locali."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下に引いて更新すると、ローカルデータから読書統計を再計算します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아래로 당겨 새로 고치면 로컬 데이터에서 독서 통계를 다시 계산합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Потяните для обновления, чтобы пересчитать статистику чтения по локальным данным."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下拉刷新以根据本地数据重新计算阅读统计。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下拉重新整理以根據本地資料重新計算閱讀統計。"
          }
        }
      }
    },
