        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "失敗したすべてのダウンロードをキャンセルしてもよろしいですか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "실패한 모든 다운로드를 취소하시겠습니까?"
          }
        },
        "ru" : {
          "stringUnit" : {
