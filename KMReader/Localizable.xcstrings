    "Decode fewer nearby pages to reduce memory usage. Page turns may wait for loading more often." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dekodiert weniger Seiten in der Nähe, um Speicher zu sparen. Beim Umblättern kann häufiger auf das Laden gewartet werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decode fewer nearby pages to reduce memory usage. Page turns may wait for loading more often."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decodifica menos páginas cercanas para reducir el uso de memoria. Al pasar página puede esperarse la carga con más frecuencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Décode moins de pages proches afin de réduire l’utilisation de la mémoire. Le changement de page peut attendre le chargement plus souvent."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Decodifica meno pagine vicine per ridurre l’uso della memoria. Il cambio pagina potrebbe attendere il caricamento più spesso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メモリ使用量を抑えるため、周辺ページのデコード数を減らします。ページ送り時に読み込み待ちが増えることがあります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메모리 사용량을 줄이기 위해 주변 페이지를 더 적게 디코딩합니다. 페이지를 넘길 때 로딩을 더 자주 기다릴 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Декодирует меньше соседних страниц, чтобы снизить расход памяти. При перелистывании загрузка может ожидаться чаще."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "减少附近页面的解码数量以降低内存占用。翻页时可能更常需要等待加载。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "減少附近頁面的解碼數量以降低記憶體使用量。翻頁時可能更常需要等待載入。"
          }
        }
      }
    },
