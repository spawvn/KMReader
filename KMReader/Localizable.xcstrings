    "Only selected libraries will be indexed. Changes affect future indexing and instance-switch reindexing." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur ausgewählte Bibliotheken werden indiziert. Änderungen wirken sich auf zukünftige Indexierungen und Neuindexierungen beim Instanzwechsel aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only selected libraries will be indexed. Changes affect future indexing and instance-switch reindexing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo se indexaran las bibliotecas seleccionadas. Los cambios afectaran la indexacion futura y la reindexacion al cambiar de instancia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seules les bibliotheques selectionnees seront indexees. Les modifications s appliquent aux indexations futures et a la reindexation lors du changement d instance."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verranno indicizzate solo le librerie selezionate. Le modifiche influenzeranno l'indicizzazione futura e la reindicizzazione al cambio istanza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選択したライブラリのみがインデックスされます。変更は今後のインデックス処理とインスタンス切り替え時の再インデックスに反映されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "선택한 라이브러리만 인덱싱됩니다. 변경 사항은 이후 인덱싱 및 인스턴스 전환 시 재인덱싱에 반영됩니다。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Будут индексироваться только выбранные библиотеки. Изменения повлияют на будущую индексацию и переиндексацию при смене инстанса."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有选中的资料库会被索引。更改会影响后续索引以及切换实例时的重建索引。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有選取的資料庫會被索引。變更會影響後續索引與切換實例時的重新索引。"
          }
        }
      }
    },
