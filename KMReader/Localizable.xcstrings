    "When disabled, connection status and task completion messages will not be shown." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn deaktiviert, werden Verbindungsstatus und Aufgabennachrichten nicht angezeigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When disabled, connection status and task completion messages will not be shown."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando esta desactivado, no se mostraran el estado de conexion ni los mensajes de tareas completadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsqu'il est désactivé, l'état de connexion et les messages de fin de tâche ne sont pas affichés."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando disabilitato, non verranno mostrati lo stato connessione e i messaggi di completamento attivita."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無効にすると接続状態やタスク完了のメッセージは表示されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비활성화하면 연결 상태 및 작업 완료 메시지가 표시되지 않습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если отключено, статус подключения и сообщения о завершении задач не будут показаны."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭后不再显示连接状态与任务完成消息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "關閉後不再顯示連線狀態與任務完成訊息。"
          }
        }
      }
    },
    "When disabled, no books will be indexed in Spotlight." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn deaktiviert, werden keine Bücher in Spotlight indiziert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When disabled, no books will be indexed in Spotlight."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando esta desactivado, no se indexara ningun libro en Spotlight."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque cette option est desactivee, aucun livre n est indexe dans Spotlight."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando disabilitato, nessun libro verra indicizzato in Spotlight."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無効にすると、Spotlight で書籍はインデックスされません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비활성화하면 Spotlight에 어떤 책도 인덱싱되지 않습니다。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если отключено, книги не будут индексироваться в Spotlight."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "禁用后，Spotlight 将不会索引任何书籍。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "停用後，Spotlight 將不會索引任何書籍。"
          }
        }
      }
    },
    "When disabled, the dashboard will not automatically refresh when SSE events are received. You can still manually refresh." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn deaktiviert, wird das Dashboard bei SSE-Ereignissen nicht automatisch aktualisiert. Manuelles Aktualisieren ist weiterhin möglich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When disabled, the dashboard will not automatically refresh when SSE events are received. You can still manually refresh."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando esta desactivado, el panel no se actualizara automaticamente al recibir eventos SSE. Aun puedes actualizar manualmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsqu'il est désactivé, le tableau de bord ne se rafraîchit pas automatiquement à la réception des événements SSE. Vous pouvez toujours le rafraîchir manuellement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando disabilitato, la dashboard non si aggiornera automaticamente alla ricezione di eventi SSE. Puoi comunque aggiornare manualmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無効にすると SSE 受信時にダッシュボードは自動更新されません。手動更新は可能です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비활성화하면 SSE 이벤트를 받을 때 대시보드가 자동으로 새로고침되지 않습니다. 수동으로 새로고침할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если отключено, панель не будет автоматически обновляться при получении SSE-событий. Вы все равно можете обновить вручную."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关闭后接收 SSE 也不会自动刷新，可手动刷新。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "關閉後即使收到 SSE 也不會自動刷新，可手動更新。"
          }
        }
      }
    },
    "When enabled, Spotlight indexes downloaded books from all libraries in the current server." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, indiziert Spotlight heruntergeladene Bücher aus allen Bibliotheken des aktuellen Servers."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, Spotlight indexes downloaded books from all libraries in the current server."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando esta activado, Spotlight indexa libros descargados de todas las bibliotecas del servidor actual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque cette option est activee, Spotlight indexe les livres telecharges de toutes les bibliotheques du serveur actuel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando abilitato, Spotlight indicizza i libri scaricati da tutte le librerie del server corrente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、Spotlight は現在のサーバーのすべてのライブラリにあるダウンロード済み書籍をインデックスします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화하면 Spotlight가 현재 서버의 모든 라이브러리에 있는 다운로드된 책을 인덱싱합니다。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если включено, Spotlight индексирует загруженные книги из всех библиотек текущего сервера."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用后，Spotlight 会索引当前服务器中所有资料库里已下载的书籍。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟用後，Spotlight 會索引目前伺服器中所有資料庫裡已下載的書籍。"
          }
        }
      }
    },
