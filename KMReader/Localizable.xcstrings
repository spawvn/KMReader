    "settings.offline.auto_delete_read.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gelesene Bücher werden während der Synchronisierung automatisch gelöscht, außer sie sind durch eine Offline-Richtlinie geschützt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Read books are automatically deleted during sync unless they are protected by an offline policy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los libros leídos se eliminan automáticamente durante la sincronización, salvo que estén protegidos por una política sin conexión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les livres lus sont automatiquement supprimés pendant la synchronisation, sauf s'ils sont protégés par une règle hors ligne."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I libri letti vengono eliminati automaticamente durante la sincronizzazione, tranne quelli protetti da un criterio offline."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同期時に既読の本は自動的に削除されますが、オフラインポリシーで保護された本は保持されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "동기화 중 읽은 도서는 자동으로 삭제되지만 오프라인 정책으로 보호되는 도서는 유지됩니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прочитанные книги автоматически удаляются во время синхронизации, кроме защищенных офлайн-политикой."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同步时会自动删除已读书籍，受离线策略保护的书籍除外。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同步時會自動刪除已讀書籍，受離線策略保護的書籍除外。"
          }
        }
      }
    },
