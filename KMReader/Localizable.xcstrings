    "Auto scale only when required scale to fit the page on screen is greater than this value." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatisch nur hochskalieren, wenn der zum Einpassen der Seite auf dem Bildschirm erforderliche Skalierungsfaktor größer als dieser Wert ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auto scale only when required scale to fit the page on screen is greater than this value."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplicar autoescalado solo cuando la escala necesaria para ajustar la pagina a la pantalla supere este valor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effectuer une mise à l'échelle automatique uniquement lorsque le facteur requis pour adapter la page à l'écran est supérieur à cette valeur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applica la scalatura automatica solo quando la scala necessaria per adattare la pagina allo schermo supera questo valore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ページを画面内に収めるために必要な拡大率がこの値より大きい場合のみ自動で拡大します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "페이지를 화면에 맞추는 데 필요한 배율이 이 값보다 클 때만 자동으로 확대합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Применять автомасштабирование только если требуемый масштаб для подгонки страницы под экран больше этого значения."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅当页面适配屏幕所需的缩放倍率大于此值时才自动放大。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅當頁面適配螢幕所需的縮放倍率大於此值時才自動放大。"
          }
        }
      }
    },
