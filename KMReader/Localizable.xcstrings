    "The quick brown fox jumps over the lazy dog. This is a sample text to preview your reading preferences." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der schnelle braune Fuchs springt über den faulen Hund. Dies ist ein Beispieltext zur Vorschau Ihrer Leseeinstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The quick brown fox jumps over the lazy dog. This is a sample text to preview your reading preferences."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El veloz zorro marron salta sobre el perro perezoso. Este es un texto de ejemplo para previsualizar tus preferencias de lectura."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le rapide renard brun saute par-dessus le chien paresseux. Ceci est un exemple de texte pour prévisualiser vos préférences de lecture."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La rapida volpe marrone salta sopra il cane pigro. Questo e un testo di esempio per visualizzare in anteprima le preferenze di lettura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "素早い茶色のキツネが怠け者の犬を飛び越えます。これは読書設定をプレビューするためのサンプルテキストです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "빠른 갈색 여우가 게으른 개를 뛰어넘습니다. 이것은 읽기 설정을 미리 보기 위한 샘플 텍스트입니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Быстрая бурая лиса перепрыгивает через ленивую собаку. Это пример текста для предпросмотра ваших настроек чтения."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速的棕色狐狸跳过懒狗。这是一段示例文本，用于预览您的阅读偏好设置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速的棕色狐狸跳過懶狗。這是一段示例文本，用於預覽您的閱讀偏好設定。"
          }
        }
      }
    },
