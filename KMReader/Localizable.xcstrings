    "Are you sure you want to cancel all failed downloads?" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher, dass Sie alle fehlgeschlagenen Downloads abbrechen möchten?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to cancel all failed downloads?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguro que quieres cancelar todas las descargas fallidas?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir annuler tous les téléchargements échoués ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler annullare tutti i download non riusciti?"
          }
