    "Use the default preloading window for a balance between memory usage and smooth page turns." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwendet das Standard-Vorladefenster für ein Gleichgewicht zwischen Speicherverbrauch und flüssigem Umblättern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use the default preloading window for a balance between memory usage and smooth page turns."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa la ventana de precarga predeterminada para equilibrar memoria y fluidez al pasar página."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilise la fenêtre de préchargement par défaut pour équilibrer mémoire et fluidité du changement de page."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa la finestra di precaricamento predefinita per bilanciare memoria e fluidità del cambio pagina."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "標準の先読み範囲を使い、メモリ使用量とスムーズなページ送りのバランスを取ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기본 미리 불러오기 범위를 사용해 메모리 사용량과 부드러운 페이지 넘김의 균형을 맞춥니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Использует стандартное окно предзагрузки для баланса между памятью и плавным перелистыванием."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用默认预加载窗口，在内存占用和流畅翻页之间取得平衡。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用預設預載入範圍，在記憶體使用量與流暢翻頁之間取得平衡。"
          }
        }
      }
    },
