    "Keep book progress pinned to the bottom until reader controls are shown." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buchfortschritt unten angeheftet lassen, bis die Lesersteuerung angezeigt wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep book progress pinned to the bottom until reader controls are shown."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén el progreso del libro fijado abajo hasta que se muestren los controles de lectura."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gardez la progression du livre épinglée en bas jusqu’à l’affichage des commandes de lecture."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantieni l’avanzamento del libro fissato in basso finché non vengono mostrati i controlli di lettura."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リーダー操作部が表示されるまで、本の進捗を下部に固定します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "리더 컨트롤이 표시될 때까지 책 진행률을 하단에 고정합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Закреплять прогресс книги внизу, пока не будут показаны элементы управления чтением."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在显示阅读控制前，将书籍进度固定在底部。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在顯示閱讀控制項前，將書籍進度固定在底部。"
          }
        }
      }
    },
    "Keep more nearby pages decoded for smoother page turns at the cost of higher memory usage." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hält mehr Seiten in der Nähe dekodiert, um flüssiger umzublättern, benötigt aber mehr Speicher."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep more nearby pages decoded for smoother page turns at the cost of higher memory usage."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantiene más páginas cercanas decodificadas para pasar página con mayor fluidez, a costa de más memoria."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Garde davantage de pages proches décodées pour des changements de page plus fluides, au prix d’une mémoire plus élevée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantiene decodificate più pagine vicine per cambi pagina più fluidi, usando più memoria."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "よりスムーズにページを送るため周辺ページを多めにデコードして保持しますが、メモリ使用量は増えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "더 부드럽게 페이지를 넘기기 위해 주변 페이지를 더 많이 디코딩해 유지하지만 메모리 사용량이 늘어납니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Держит больше соседних страниц декодированными для более плавного перелистывания ценой большего расхода памяти."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保留更多已解码的附近页面以获得更流畅的翻页，但会增加内存占用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保留更多已解碼的附近頁面以獲得更流暢的翻頁，但會增加記憶體使用量。"
          }
        }
      }
    },
    "Keep time and battery visible when controls are hidden." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uhrzeit und Batteriestand sichtbar lassen, wenn die Steuerung ausgeblendet ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep time and battery visible when controls are hidden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén visibles la hora y la batería cuando los controles estén ocultos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Garder l’heure et la batterie visibles lorsque les commandes sont masquées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantieni visibili ora e batteria quando i controlli sono nascosti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コントロールを隠している間も時刻とバッテリー残量を表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "컨트롤이 숨겨져 있어도 시간과 배터리를 계속 표시합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
