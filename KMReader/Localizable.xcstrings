    "Improve clarity for low-resolution pages using built-in waifu2x (2x)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbessert die Klarheit von Bildern mit niedriger Auflösung mit integriertem waifu2x (2x)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Improve clarity for low-resolution pages using built-in waifu2x (2x)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mejora la nitidez de paginas de baja resolucion con waifu2x integrado (2x)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Améliore la netteté des images basse résolution grâce à waifu2x intégré (2x)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Migliora la nitidezza delle pagine a bassa risoluzione con waifu2x integrato (2x)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内蔵の waifu2x（2x）で低解像度ページの鮮明さを向上します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "내장 waifu2x(2x)를 사용해 저해상도 페이지의 선명도를 높입니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Повышайте четкость страниц низкого разрешения с помощью встроенного waifu2x (2x)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用内置 waifu2x（2x）提升低分辨率页面清晰度。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用內建 waifu2x（2x）提升低解析度頁面的清晰度。"
          }
        }
      }
    },
    "In Always mode, upscale unless source width or height exceeds this multiple of the screen." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Im Immer-Modus wird hochskaliert, außer wenn Quellbreite oder -höhe dieses Vielfache der Bildschirmgröße überschreitet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In Always mode, upscale unless source width or height exceeds this multiple of the screen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En modo Siempre, ampliar salvo que el ancho o alto de origen supere este multiple de la pantalla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En mode Toujours, la mise à l'échelle est appliquée sauf si la largeur ou la hauteur source dépasse ce multiple de la taille d'écran."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In modalita Sempre, esegue l'upscale salvo quando larghezza o altezza sorgente superano questo multiplo dello schermo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "常時モードでは、元画像の幅または高さが画面サイズのこの倍率を超えない限り拡大します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "항상 모드에서는 원본 너비 또는 높이가 화면 크기의 이 배수를 초과하지 않는 한 업스케일합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В режиме «Всегда» увеличивать, если ширина или высота исходника не превышает этот множитель экрана."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在始终模式下，除非源图宽度或高度超过屏幕尺寸的此倍数，否则都会放大。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在始終模式下，除非來源圖片寬度或高度超過螢幕尺寸的此倍數，否則都會放大。"
          }
        }
      }
    },
    "In single page mode, split landscape pages into two separate pages" : {
